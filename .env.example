# Docker Compose Developer Infrastructure — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is listed in .gitignore.

# ---------------------------------------------------------------------------
# Required — SQL Server SA password
# Must meet SQL Server complexity requirements:
#   - At least 8 characters
#   - Mix of uppercase letters, lowercase letters, digits, and at least one
#     non-alphanumeric character (e.g. ! @ # $ % ^ & *)
# ---------------------------------------------------------------------------
SA_PASSWORD=<your-strong-password-here>

# ---------------------------------------------------------------------------
# Optional — Host port for SQL Server (default: 1433)
# Change this if port 1433 is already occupied by a local SQL Server instance.
# ---------------------------------------------------------------------------
SQL_PORT=1433

# ---------------------------------------------------------------------------
# Optional — ASP.NET Core connection string overrides
# These override appsettings.json when set, enabling use of the Docker SQL
# Server instance without modifying any source-controlled file.
# Replace <your-strong-password-here> with the same value as SA_PASSWORD above.
# IMPORTANT: Keep the single quotes — they prevent the shell from mis-splitting
# the value on semicolons and special characters when you run: set -a && source .env && set +a
# ---------------------------------------------------------------------------
ConnectionStrings__CarrotwareCMS='Server=localhost,1433;Database=CarrotCoreMVC;uid=sa;Password=<your-strong-password-here>;MultipleActiveResultSets=true;Encrypt=False;TrustServerCertificate=True;'
ConnectionStrings__NorthwindConnection='Server=localhost,1433;Database=Northwind;uid=sa;Password=<your-strong-password-here>;MultipleActiveResultSets=true;Encrypt=False;TrustServerCertificate=True;'
